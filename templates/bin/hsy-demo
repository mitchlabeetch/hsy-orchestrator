  log('   💡 NEXT: /hsy-next-work-run\n', 'reset');
  
  await sleep(1000);
  
  log('📥 Orchestrator receives result:', 'magenta');
  log('   ✅ Hook completed successfully', 'green');
  log('   📝 Updated state', 'reset');
  log('   📊 Logged execution\n', 'reset');
  
